---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/Card/index.astro";
import GlowingStarsBanner from "../../components/GlowingStarsBanner";

const posts = (await getCollection("blog")).sort(
  (blogEntryA, blogEntryB) =>
    blogEntryB.data.pubDate.getTime() - blogEntryA.data.pubDate.getTime(),
);
---

<script>
  import { timeline, type TimelineDefinition } from "motion";
  import { loaderAnimation } from "../../lib/constants";

  const sequence = [loaderAnimation];

  timeline(sequence as TimelineDefinition);
</script>

<Layout
  title="Cuong Luu - Notes"
  description="Notes on medicine, neuroscience, & philosophy + their communication"
>
  <main
    class="w-screen min-h-screen flex flex-col justify-start items-start max-w-3xl mx-auto p-8"
  >
    <a
      href="/"
      class="text-white bg-neutral-900 hover:bg-neutral-800 px-4 py-2 mb-8 border-1 border-solid border-neutral-600 rounded-lg"
      >Back</a
    >
    <div class="w-full mb-8 flex justify-center overflow-hidden">
      <GlowingStarsBanner client:load />
    </div>
    <div class="grid grid-cols-1 gap-4 w-full">
      {
        posts.map((post) => (
          <Card href={`/notes/${post.slug}`} colSpan="md:col-span-1" padding="px-6 py-[14px]">
            <div>
              <h2 class="font-semibold text-2xl text-white">
                {post.data.title}
              </h2>
              <p class="mt-[2px] text-neutral-400">{post.data.description}</p>
            </div>
          </Card>
        ))
      }
    </div>
  </main>
</Layout>
