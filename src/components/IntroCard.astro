---
import Card from "./Card/index.astro";
import Button from "./Button.astro";
import { LINKS } from "../lib/constants";
import { Icon } from "astro-icon/components";
import Tooltip from "./Tooltip/index";
---

<Card colSpan="md:col-span-3 lg:col-span-7" rowSpan="md:row-span-4">
  <div class="flex w-full h-full">
    <div class="flex flex-col justify-between md:max-h-[300px] gap-4">
      <div class="flex flex-col h-full">
        <h6 class="text-sm font-light m-0 text-gray-500">Welcome</h6>
        <p class="m-0 font-light text-xl">
          Xin chào, I'm <b class="font-bold">Cường P. Luu</b>, a medical
          graduate with a strong focus on advancing neurosurgical care,
          neuro-functional research, and the philosophy of mind.
        </p>
      </div>

      <div class="m-0 flex gap-4">
        <a href={LINKS.cv} aria-label="cv doc" target="_blank">
          <Button aria-label="cv doc">
            <span class="cv-btn-content">
              <Icon
                name="academicons:cv"
                class="h-[40px] w-[40px]"
                style="font-size: 40px;"
              />
              <span class="cv-text">(Curriculum Vitae)</span>
            </span>
          </Button>
        </a>

        <!-- <a href={LINKS.googlescholar} aria-label="google scholar profile" target="_blank">
          <Button aria-label="google scholar profile">
            <Icon name="academicons:google-scholar-square" class="h-6" />
            <span class="sr-only">Dribble Profile</span>
          </Button>
        </a> -->

        <!-- <a href={LINKS.bluesky} aria-label="bluesky profile" target="_blank">
          <Button aria-label="bluesky profile">
            <Icon name="ri:bluesky-fill" class="h-[30px]" />
            <span class="sr-only">GitHub Profile</span>
          </Button>
        </a> -->

        <!-- <a href={LINKS.instagram} aria-label="instagram profile" target="_blank">
          <Button aria-label="instagram profile">
            <Icon name="ri:instagram-fill" class="h-6" />
            <span class="sr-only">Dribble Profile</span>
          </Button>
        </a> -->

        <Tooltip client:visible>
          <Button aria-label="easter egg btn">
            <Icon name="noto:lotus" class="h-[35px] w-[35px]" />
            <span class="sr-only">Easter egg button</span>
          </Button>
        </Tooltip>
      </div>
    </div>

    <img
      width="300"
      height="300"
      src="/cuong-luu-medicine-portrait.png"
      class="w-auto max-h-[300px] select-none absolute right-[-65px] bottom-[-20px] z-[-1] opacity-50 md:opacity-100 md:relative md:right-auto md:bottom-auto md:z-auto pointer-events-none"
      alt="Portrait photo of Cuong P. Luu in white coat"
    />
  </div>
</Card>

<style>
  .cv-btn-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .cv-text {
    color: rgb(229, 231, 235); /* text-gray-200 equivalent */
    font-weight: 700;
    font-size: 1rem;
    line-height: 1;
    transition: color 270ms ease-in-out;
    white-space: nowrap;
  }

  /* When the parent button is hovered or active, turn text red */
  :global(.custom-btn:hover) .cv-text,
  :global(.custom-btn:active) .cv-text {
    color: var(--color-primary-500, #ef4444);
  }
</style>
